# ════════════════════════════════════════════════
#  Cursogram - Required
# ════════════════════════════════════════════════

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token

# Telegram user IDs (comma-separated). Get from @userinfobot
ALLOWED_USER_IDS=123456789

# Cursor API key (cursor.com/dashboard) - required for Cursor CLI
CURSOR_API_KEY=crsr_xxxxxxxxxxxx

# ════════════════════════════════════════════════
#  Optional
# ════════════════════════════════════════════════

# Dangerous mode - auto-approve tool permissions (use with caution)
DANGEROUS_MODE=false

# streaming = live replies | wait = full reply when done
STREAMING_MODE=streaming

# Publish long replies to Telegraph
TELEGRAPH_ENABLED=false

# Cursor CLI path (default: agent)
# CURSOR_CLI_PATH=agent

# ════════════════════════════════════════════════
#  Voice / TTS
# ════════════════════════════════════════════════

TRANSCRIBE_ENABLED=false
GROQ_API_KEY=
VOICE_LANGUAGE=en

TTS_ENABLED=false
OPENAI_API_KEY=

# ════════════════════════════════════════════════
#  MCP - Dokploy
# ════════════════════════════════════════════════

DOKPLOY_MCP_ENABLED=false
DOKPLOY_URL=
DOKPLOY_API_KEY=

# ════════════════════════════════════════════════
#  MCP - GitHub
# ════════════════════════════════════════════════

GH_TOKEN=
GITHUB_MCP_ENABLED=false
