# ════════════════════════════════════════════════
#  Required
# ════════════════════════════════════════════════

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=87788**************

# Telegram user IDs allowed to use the bot
# Get it from @userinfobot
ALLOWED_USER_IDS=7119288852

# ════════════════════════════════════════════════
#  Authentication - choose one method only
# ════════════════════════════════════════════════

# ── Method 1 (preferred): OAuth token - for Claude Max/Pro subscribers ──
# Steps:
#   1. On Mac run:  claude login
#   2. Then run:    claude setup-token
#   3. Copy the generated token (starts with sk-ant-oat01-...)
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-zzzzzzz

# ── Method 2 (alternative): API Key - from console.anthropic.com ──
# Use this instead of OAuth if you pay for usage directly
# ANTHROPIC_API_KEY=sk-ant-api03-...

# ════════════════════════════════════════════════
#  Optional settings
# ════════════════════════════════════════════════

# Dangerous mode - automatically approves all tool permissions
# Leave it false in production for security reasons
DANGEROUS_MODE=false

# Streaming mode: streaming = instant partial replies | wait = wait for full reply
STREAMING_MODE=streaming

# Publish long replies on Telegraph
TELEGRAPH_ENABLED=false

# ════════════════════════════════════════════════
#  Voice (optional)
# ════════════════════════════════════════════════

# Enable converting voice messages to text
TRANSCRIBE_ENABLED=false

# Groq key for Whisper (free)
# From https://console.groq.com/
GROQ_API_KEY=gsk_HlfzgV6UmzG1ix9GzKzzzzzzzz

VOICE_LANGUAGE=ar

# ════════════════════════════════════════════════
#  TTS - Text to Speech (optional)
# ════════════════════════════════════════════════

TTS_ENABLED=false

# OpenAI API key if you want high-quality TTS
OPENAI_API_KEY=
