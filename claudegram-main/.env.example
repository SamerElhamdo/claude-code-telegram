# ════════════════════════════════════════════════
#  Cursogram - Cursor CLI Telegram Bot
# ════════════════════════════════════════════════

# ── Required ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
ALLOWED_USER_IDS=123456789
CURSOR_API_KEY=crsr_xxxxxxxxxxxx

# ── Response ─────────────────────────────────────────────
STREAMING_MODE=streaming
DANGEROUS_MODE=false
TELEGRAPH_ENABLED=false

# ── Voice / TTS ───────────────────────────────────────────
TRANSCRIBE_ENABLED=false
GROQ_API_KEY=
VOICE_LANGUAGE=en
TTS_ENABLED=false
# OPENAI_API_KEY=

# ── Reddit ─────────────────────────────────────────────────
REDDIT_ENABLED=true
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USERNAME=
# REDDIT_PASSWORD=

# ── Medium / Extract ───────────────────────────────────────
MEDIUM_ENABLED=true
EXTRACT_ENABLED=true

# ── MCP: Dokploy ───────────────────────────────────────────
DOKPLOY_MCP_ENABLED=false
# DOKPLOY_URL=https://your-server.com/api
# DOKPLOY_API_KEY=

# ── MCP: GitHub ────────────────────────────────────────────
# GH_TOKEN=ghp_xxxx
GITHUB_MCP_ENABLED=false

# ── Cursor CLI ─────────────────────────────────────────────
# CURSOR_CLI_PATH=agent
